# Claude (Anthropic)
ANTHROPIC_API_KEY=

# Meta (for token debug and refresh; required for Meta agent)
META_APP_ID=
META_APP_SECRET=
# Optional: cron schedule for Meta agent (default: every 6 hours). Examples: "0 */6 * * *" (6h), "0 * * * *" (hourly)
# META_AGENT_CRON=0 */6 * * *
# Optional: directory for report files (default: reports)
# REPORTS_DIR=reports

# TikTok (for token refresh; required for TikTok agent)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Optional: cron schedule for TikTok agent (default: every 6 hours)
# TIKTOK_AGENT_CRON=0 */6 * * *

# Email (optional – for alerts and reports)
# Use one of the following depending on provider:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# Or:
# SENDGRID_API_KEY=
# RESEND_API_KEY=

# Optional: global admin email for token/error alerts
# ADMIN_EMAIL=admin@example.com
